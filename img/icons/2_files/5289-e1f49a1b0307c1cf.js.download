eturn m},b9:function(){return s},hN:function(){return c},hu:function(){return a},mH:function(){return d},mg:function(){return l},o2:function(){return _},oz:function(){return h}});var i=n(13612);function r(e){return{title:(0,i.t)(e,{en:"What is px unit? (Pixels)",de:"Was ist die Einheit px? (Pixel)"}),description:(0,i.t)(e,{en:"Pixel unit is the theorical smallest dot displayed on a computer screen.\nNowadays, pixel unit can differ between physical resolution and logical resolution.\nThis difference is called device pixel ratio or DPR:\nLogical resolution = physical resolution / device pixel ratio.\nSo, a screen with 1024x768 physical resolution with a DPR of 2 will have a 512x384 logical resolution.",de:"Die Pixeleinheit ist der theoretisch kleinste Punkt, der auf einem Computerbildschirm angezeigt wird.\nHeutzutage kann die Pixeleinheit zwischen physikalischer und logischer Aufl\xf6sung variieren.\nDieser Unterschied wird als Ger\xe4tepixelverh\xe4ltnis oder DPR bezeichnet:\nLogische Aufl\xf6sung = physikalische Aufl\xf6sung / Ger\xe4tepixelverh\xe4ltnis.\nEin Bildschirm mit einer physikalischen Aufl\xf6sung von 1024 x 768 und einem DPR von 2 hat also eine logische Aufl\xf6sung von 512 x 384."})}}function o(e){return{title:(0,i.t)(e,{en:"What is rem unit?",de:"Was ist eine REM-Einheit?"}),description:(0,i.t)(e,{en:"REM is defined relative to the font size of the root element. The root element is matched by the :root pseudo-class or the html selector. 1 REM therefore takes on the value which is given to the font-size of the root element. This means that 1 REM keeps the same value throughout your whole CSS code.",de:"REM wird relativ zur Schriftgr\xf6\xdfe des Stammelements definiert. Das Stammelement wird durch die Pseudoklasse :root oder den HTML-Selektor abgeglichen. 1 REM nimmt daher den Wert an, der der Schriftgr\xf6\xdfe des Stammelements zugewiesen wird. Dies bedeutet, dass 1 REM in Ihrem gesamten CSS-Code denselben Wert beh\xe4lt."})}}function s(e){return{title:(0,i.t)(e,{en:"What is em unit?",de:"Was ist eine EM-Einheit?"}),description:(0,i.t)(e,{en:"EM is defined relative to the font size of the parent element. 1 EM therefore takes on the value which is given to the font-size of the parent element.",de:"EM wird relativ zur Schriftgr\xf6\xdfe des \xfcbergeordneten Elements definiert. 1 EM nimmt daher den Wert an, der der Schriftgr\xf6\xdfe des \xfcbergeordneten Elements zugewiesen wird."})}}function a(e){return{title:(0,i.t)(e,{en:"What is vw unit? (Viewport Width)",de:"Was ist eine VW-Einheit? (Ansichtsfenster Breite)"}),description:(0,i.t)(e,{en:"Used in responsive design, Viewport Width (VW) is a unit relative to web page display area called viewport.\n1vw corresponds to 1% of display. So, to make an element full width, you should use 100vw.\nYou can also use decimal values. Please note that, depending on browsers, decimal precision can change.",de:"Die Viewport-Breite (VW) wird im Responsive Design verwendet und ist eine Einheit im Verh\xe4ltnis zum Anzeigebereich einer Webseite, der als Viewport bezeichnet wird.\n1 VW entspricht 1 % der Anzeige. Um einem Element also die volle Breite zu geben, sollten Sie 100 VW verwenden.\nSie k\xf6nnen auch Dezimalwerte verwenden. Bitte beachten Sie, dass sich die Dezimalgenauigkeit je nach Browser \xe4ndern kann."})}}function c(e){return{title:(0,i.t)(e,{en:"What is vh unit? (Viewport Height)",de:"Was ist eine VH-Einheit? (Ansichtsfenster H\xf6he)"}),description:(0,i.t)(e,{en:"Used in responsive design, Viewport Height (VH) is a unit relative to web page display area called viewport.\n1vh corresponds to 1% of display. So, to make an element full height, you should use 100vh.\nYou can also use decimal values. Please note that, depending on browsers, decimal precision can change.",de:"Die Viewporth\xf6he (VH) wird im Responsive Design verwendet und ist eine Einheit relativ zum Anzeigebereich einer Webseite, der als Viewport bezeichnet wird.\n1 VH entspricht 1 % der Anzeige. Um einem Element also die volle H\xf6he zu geben, sollten Sie 100 VH verwenden.\nSie k\xf6nnen auch Dezimalwerte verwenden. Bitte beachten Sie, dass sich die Dezimalgenauigkeit je nach Browser \xe4ndern kann."})}}function l(e){return{title:(0,i.t)(e,{en:"What is pt unit? (Point)",de:"Was ist die Einheit pt? (Punkt)"}),description:(0,i.t)(e,{en:"A point (pt) is an absolute unit of length commonly used in the print industry and print media to achieve a pixel-perfect display of a device. One point is equivalent to 4/3 of physical pixels. Points are equal to 1/72 of an inch. 1px is equal to 0.74999943307122pt. For example, 12pt = 16px.",de:"Ein Punkt (pt) ist eine absolute L\xe4ngeneinheit, die in der Druckindustrie und bei Printmedien h\xe4ufig verwendet wird, um eine pixelgenaue Anzeige eines Ger\xe4ts zu erreichen. Ein Punkt entspricht 4/3 der physischen Pixel. Punkte entsprechen 1/72 Zoll. 1px entspricht 0,74999943307122pt. Beispielsweise sind 12pt = 16px."})}}function u(e){return{title:(0,i.t)(e,{en:"What is in unit? (Inch)",de:"Was ist in der Einheit? (Zoll)"}),description:(0,i.t)(e,{en:"An inch (in) is an absolute unit of length. One inch is equivalent to 96px or 2.54cm",de:"Ein Zoll (in) ist eine absolute L\xe4ngeneinheit. Ein Zoll entspricht 96px oder 2,54cm"})}}function _(e){return{title:(0,i.t)(e,{en:"What is pc unit? (Pica)",de:"Was ist eine PC-Einheit? (Pica)"}),description:(0,i.t)(e,{en:"A pica (pc) is an absolute unit of length. One pc is equivalent to 16px, and one px is equivalent to 0.0625pc",de:"Eine Pica (pc) ist eine absolute L\xe4ngeneinheit. Ein pc entspricht 16px und ein px entspricht 0,0625pc"})}}function d(e){return{title:(0,i.t)(e,{en:"What is cm unit? (Centimeter)",de:"Was ist die Einheit cm? (Zentimeter)"}),description:(0,i.t)(e,{en:"A centimeter (cm) is an absolute unit of length. 1cm is roughly 37.8 pixels, or about 25.2/64 of an inch. 1px is equivalent to 0.0264583333cm",de:"Ein Zentimeter (cm) ist eine absolute L\xe4ngeneinheit. 1 cm sind etwa 37,8 Pixel oder etwa 25,2/64 Zoll. 1 Pixel entspricht 0,0264583333 cm"})}}function h(e){return{title:(0,i.t)(e,{en:"What is mm unit? (Millimeter)",de:"Was ist die Einheit mm? (Millimeter)"}),description:(0,i.t)(e,{en:"A millimeter (mm) is an absolute unit of length. 1mm is roughly 3.8 pixels, or about 25.2/640 of an inch. 1px is equivalent to 0.2645833333mm",de:"Ein Millimeter (mm) ist eine absolute L\xe4ngeneinheit. 1 mm sind etwa 3,8 Pixel oder etwa 25,2/640 Zoll. 1 Pixel entspricht 0,2645833333 mm."})}}function p(e){return{title:(0,i.t)(e,{en:"What is % unit? (Percentage)",de:"Was ist die Einheit %? (Prozentsatz)"}),description:(0,i.t)(e,{en:"Percentage is a number or ratio expressed as a fraction of 100. It is often denoted using the percent sign (%). A percentage is a dimensionless number, primarily used for expressing proportions, but percent is nonetheless a unit of measurement in its orthography and usage.\n In CSS, it is often used to define a size as relative to an element's parent element. For example, if parent element's size is 1000px, then 1% will be equal to 10px, 1% = 10px.",de:"Ein Prozentsatz ist eine Zahl oder ein Verh\xe4ltnis, das als Bruchteil von 100 ausgedr\xfcckt wird. Er wird h\xe4ufig mit dem Prozentzeichen (%) angegeben. Ein Prozentsatz ist eine dimensionslose Zahl, die haupts\xe4chlich zum Ausdr\xfccken von Proportionen verwendet wird. Dennoch ist Prozent in seiner Rechtschreibung und Verwendung eine Ma\xdfeinheit.\nIn CSS wird er h\xe4ufig verwendet, um eine Gr\xf6\xdfe relativ zum \xfcbergeordneten Element eines Elements zu definieren. Wenn beispielsweise die Gr\xf6\xdfe des \xfcbergeordneten Elements 1000 Pixel betr\xe4gt, entspricht 1 % 10 Pixel, 1 % = 10 Pixel."})}}function m(e){return{title:(0,i.t)(e,{en:"What are common breakpoints for media queries?",de:"Was sind g\xe4ngige Haltepunkte f\xfcr Medienabfragen?"}),description:(0,i.t)(e,{en:"Mobile devices – 320px — 480px.\niPads, Tablets – 481px — 768px.\nSmall screens, laptops – 